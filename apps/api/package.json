{
  "name": "@bolao/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "bracket:print": "ts-node --transpile-only prisma/regen-knockout.ts",
    "bracket:regen": "ts-node --transpile-only prisma/regen-knockout.ts --apply",
    "bracket:reset-list": "ts-node --transpile-only prisma/reset-knockout-brackets.ts",
    "bracket:reset": "ts-node --transpile-only prisma/reset-knockout-brackets.ts --apply",
    "prisma": "prisma"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@bolao/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.77.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-stringify": "^6.7.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "nanoid": "^5.0.7",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@playwright/test": "^1.49.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.12",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
