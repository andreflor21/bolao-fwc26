NODE_ENV=development

DATABASE_URL=postgresql://bolao:bolao_dev@localhost:5432/bolao?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_TLS=false

API_PORT=3001
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173

JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

BCRYPT_COST=12

# Email
EMAIL_FROM="Bolão Copa 2026 <noreply@bolao.local>"
EMAIL_DRIVER=mock                # mock | resend
RESEND_API_KEY=

# Stripe (Pix BR) — setup completo em docs/stripe-setup.md
# Em dev, usar stripe-cli para forwardar webhooks pra api local:
#   stripe listen --forward-to localhost:3001/api/v1/webhooks/stripe
# O comando imprime um whsec_... temporário — cole em STRIPE_WEBHOOK_SECRET.
STRIPE_DRIVER=stripe             # mock | stripe (mock só em CI/dev offline)
STRIPE_SECRET_KEY=               # sk_test_... (Developers → API keys → Reveal test key)
STRIPE_PUBLISHABLE_KEY=          # pk_test_... (mesmo painel; exposto ao web via VITE_STRIPE_PUBLISHABLE_KEY)
STRIPE_WEBHOOK_SECRET=           # whsec_... (do `stripe listen` em dev; Endpoint signing secret do dashboard em prod)
# Métodos do Stripe Checkout (lista separada por vírgula). Default: card,link,boleto.
# Adicione "pix" quando sua conta tiver Pix liberado (60 dias após KYC BR).
STRIPE_CHECKOUT_METHODS=card,link,boleto
STRIPE_BOLETO_EXPIRES_AFTER_DAYS=3

# Web Push (VAPID). Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bolao.app

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info                   # trace | debug | info | warn | error

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100
LOGIN_THROTTLE_LIMIT=5
LOGIN_THROTTLE_TTL=900

# Competition
COMPETITION_LOCKS_AT=2026-06-11T19:00:00Z              # group palpites lock (apito do 1º jogo)
COMPETITION_KO_LOCKS_AT=2026-06-30T17:00:00Z          # knockout palpites lock — 1h antes do 1º KO
COMPETITION_ENDS_AT=2026-07-19T23:59:59Z
SUBSCRIPTION_AMOUNT_CENTS=5000

# Frontend (Vite — only VITE_ prefixed vars are exposed)
VITE_API_URL=http://localhost:3001/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_VAPID_PUBLIC_KEY=
VITE_SENTRY_DSN=
