NODE_ENV=development

DATABASE_URL=postgresql://bolao:bolao_dev@localhost:5432/bolao?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_TLS=false

API_PORT=3001
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173

JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

BCRYPT_COST=12

# Email
EMAIL_FROM="Bolão Copa 2026 <noreply@bolao.local>"
EMAIL_DRIVER=mock                # mock | resend
RESEND_API_KEY=

# Stripe (Pix BR) — setup completo em docs/stripe-setup.md
# Em dev, usar stripe-cli para forwardar webhooks pra api local:
#   stripe listen --forward-to localhost:3001/api/v1/webhooks/stripe
# O comando imprime um whsec_... temporário — cole em STRIPE_WEBHOOK_SECRET.
# Eventos do webhook (Dashboard → Developers → Webhooks → Select events):
#   checkout.session.completed                  (card, Link, Apple Pay)
#   checkout.session.async_payment_succeeded    (boleto pago no banco)
#   checkout.session.async_payment_failed       (boleto vencido)
#   checkout.session.expired                    (TTL de 24h da sessão)
#   payment_intent.succeeded
#   payment_intent.payment_failed
#   payment_intent.canceled
#   charge.refunded                             (cobre refund total e parcial)
STRIPE_DRIVER=stripe             # mock | stripe (mock só em CI/dev offline)
STRIPE_SECRET_KEY=               # sk_test_... (Developers → API keys → Reveal test key)
STRIPE_PUBLISHABLE_KEY=          # pk_test_... (mesmo painel; exposto ao web via VITE_STRIPE_PUBLISHABLE_KEY)
STRIPE_WEBHOOK_SECRET=           # whsec_... (do `stripe listen` em dev; Endpoint signing secret do dashboard em prod)
# Métodos do Stripe Checkout (lista separada por vírgula). Default: card,link,boleto.
# Adicione "pix" quando sua conta tiver Pix liberado (60 dias após KYC BR).
STRIPE_CHECKOUT_METHODS=card,link,boleto
STRIPE_BOLETO_EXPIRES_AFTER_DAYS=3

# Pix manual fallback. Enquanto a conta Stripe BR não libera Pix (KYC 60d), o
# jogador pode pagar por BR Code estático e enviar o comprovante; Claude
# (visão) lê o comprovante, confere valor + chave Pix + recipient e ativa a
# inscrição automaticamente. Em caso de dúvida cai para manual_review.
PIX_FALLBACK_ENABLED=false
PIX_FALLBACK_PAYLOAD=             # BR Code "copia e cola" gerado no app do banco
PIX_FALLBACK_PIX_KEY=             # chave Pix do recebedor (UUID/email/telefone — pode não aparecer no comprovante)
PIX_FALLBACK_RECIPIENT_NAME=      # nome/razão social do recebedor
PIX_FALLBACK_RECIPIENT_CNPJ=      # CPF/CNPJ do recebedor, só dígitos (Itaú costuma mostrar isso em vez da chave UUID)
ANTHROPIC_API_KEY=                # sk-ant-... (Console: console.anthropic.com)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# WhatsApp broadcast (admin dispara mensagens no grupo, com presets gerados por IA).
# Provider 'mock' (ou vazio) só loga no console — usar em dev/CI. Em prod usar 'evolution'.
# Para o JID do grupo, abra o grupo no WhatsApp Web, copie o ID (termina em @g.us).
WHATSAPP_PROVIDER=mock            # mock | evolution
EVOLUTION_API_URL=                # ex.: https://evolution.meudominio.com
EVOLUTION_API_KEY=                # apikey global ou da instância
EVOLUTION_INSTANCE=               # nome da instância criada na Evolution API
WHATSAPP_GROUP_JID=               # ex.: 120363xxxxxxxxxxx@g.us

# Web Push (VAPID). Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bolao.app

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info                   # trace | debug | info | warn | error

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100
LOGIN_THROTTLE_LIMIT=5
LOGIN_THROTTLE_TTL=900

# Competition
COMPETITION_LOCKS_AT=2026-06-11T19:00:00Z              # apito do 1º jogo da Copa. A TRAVA GERAL (grupos + mata-mata) é 1h antes disso.
# COMPETITION_KO_LOCKS_AT — OBSOLETA: o mata-mata agora usa a mesma trava geral (1h antes do 1º jogo da Copa).
COMPETITION_ENDS_AT=2026-07-19T23:59:59Z
SUBSCRIPTION_AMOUNT_CENTS=5000
# Sobretaxa (centavos) somada SÓ ao valor cobrado no Stripe Checkout para cobrir
# a taxa da operação (cartão 3,99%+R$0,39 / boleto R$3,45 fixo). NÃO entra no
# pool/prêmio (que continua em SUBSCRIPTION_AMOUNT_CENTS líquido). Valor único
# p/ todos os métodos — use o pior caso (boleto) p/ garantir líquido >= R$50.
# 345 = R$3,45 → cartão paga R$53,45 (sobra ~R$0,93), boleto fica exato.
SUBSCRIPTION_SURCHARGE_CENTS=345

# Frontend (Vite — only VITE_ prefixed vars are exposed)
VITE_API_URL=http://localhost:3001/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_VAPID_PUBLIC_KEY=
VITE_SENTRY_DSN=
